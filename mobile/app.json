{
  "expo": {
    "name": "AMP",
    "slug": "amp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ],
      "package": "com.anonymous.ampmobile"
    },
    "extra": {
      "eas": {
        "projectId": "d27b1585-50a7-46d4-898e-2f2451ce99a9"
      }
    },
    "owner": "ampproject",
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Precisamos de acesso à galeria para trocar a foto do perfil."
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyC5Y2D1lq5Z0e4p9r2X7v4Y9w3Q1a2Z0x"
        }
      ]
    ]
  }
}
