# Flask Config
SECRET_KEY=your-secret-key-here
FLASK_APP=run.py
FLASK_ENV=production

# Database
DATABASE_URL=sqlite:///amp_db.db
# Para PostgreSQL: DATABASE_URL=postgresql://user:password@host:port/dbname
# Para MySQL: DATABASE_URL=mysql+pymysql://user:password@host:port/dbname

# OpenAI API (opcional)
OPENAI_API_KEY=your-openai-api-key-here

